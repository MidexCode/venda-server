{
  "name": "venda-server",
  "version": "1.0.0",
  "description": "REST API for Venda — a full-stack Nigerian marketplace. Built with Node.js, Express, TypeScript, Prisma, and PostgreSQL. Features auth via Clerk, payments via Paystack, image uploads via Cloudinary, and email via Resend.",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "ts-node prisma/seed.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MidexCode/venda-server.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/MidexCode/venda-server/issues"
  },
  "homepage": "https://github.com/MidexCode/venda-server#readme",
  "dependencies": {
    "@clerk/express": "^2.1.23",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "morgan": "^1.11.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "resend": "^6.12.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
